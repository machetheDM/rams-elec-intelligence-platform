# Groq API key for LLM classification (free tier available at console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# PostgreSQL connection (same as Prisma DATABASE_URL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ramsatelec

# MLflow tracking URI
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# Service port
TRIAGE_PORT=8001
