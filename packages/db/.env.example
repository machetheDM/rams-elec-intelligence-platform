# PostgreSQL connection string (Supabase or local)
# For Supabase: postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# For local:    postgresql://postgres:postgres@localhost:5432/ramsatelec
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ramsatelec"

# Direct URL for migrations (Supabase requires connection pooling for serverless)
