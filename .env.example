# =============================================================================
# Rams @Elec Intelligence Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your keys.
# [REQUIRED] = must be set for the service to function
# [OPTIONAL] = service degrades gracefully without it

# =============================================================================
# DATABASE (REQUIRED)
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rams_elec
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/rams_elec

# =============================================================================
# NEXT.JS / NEXTAUTH (REQUIRED)
# =============================================================================
AUTH_SECRET=generate-a-random-secret-here                       # [REQUIRED] openssl rand -base64 32
AUTH_URL=http://localhost:3000                                   # [REQUIRED]

# =============================================================================
# ADMIN (REQUIRED)
# =============================================================================
ADMIN_TOKEN=rams-elec-admin-2026                                 # [REQUIRED]

# =============================================================================
# GROQ LLM API (REQUIRED for AI features)
# =============================================================================
# Free tier available at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here                                  # [REQUIRED]

# =============================================================================
# TWILIO (REQUIRED for WhatsApp/SMS notifications)
# =============================================================================
TWILIO_ACCOUNT_SID=your_twilio_sid                              # [REQUIRED]
TWILIO_AUTH_TOKEN=your_twilio_token                             # [REQUIRED]
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886                      # [REQUIRED]
TWILIO_SMS_FROM=+1234567890                                     # [OPTIONAL]

# =============================================================================
# ESKOMSEPUSH (REQUIRED for load-shedding)
# =============================================================================
# Free tier available at https://eskomsepush.gumroad.com/l/api
ESKOM_SE_PUSH_API_KEY=your_esp_key_here                         # [REQUIRED]

# =============================================================================
# AIRFLOW (REQUIRED for ETL orchestration)
# =============================================================================
AIRFLOW__CORE__FERNET_KEY=generate-with-python                  # [REQUIRED]
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://postgres:postgres@postgres:5432/rams_elec  # [REQUIRED]

# =============================================================================
# N8N (REQUIRED for automation workflows)
# =============================================================================
N8N_BASIC_AUTH_USER=admin                                       # [REQUIRED]
N8N_BASIC_AUTH_PASSWORD=change-me-in-production                 # [REQUIRED]
N8N_WEBHOOK_URL=http://localhost:5678                           # [REQUIRED]

# =============================================================================
# MLFLOW (OPTIONAL — for model tracking)
# =============================================================================
MLFLOW_TRACKING_URI=http://localhost:5000                       # [OPTIONAL]

# =============================================================================
# INTERNAL SERVICE URLS (REQUIRED for inter-service communication)
# =============================================================================
TRIAGE_SERVICE_URL=http://localhost:8001                        # [REQUIRED]
LOADSHEDDING_SERVICE_URL=http://localhost:8002                  # [REQUIRED]
CHATBOT_SERVICE_URL=http://localhost:8003                       # [REQUIRED]
DISPATCH_SERVICE_URL=http://localhost:8004                      # [REQUIRED]

# =============================================================================
# SERVICE PORTS (OPTIONAL — defaults shown)
# =============================================================================
TRIAGE_PORT=8001                                                # [OPTIONAL]
LOADSHEDDING_PORT=8002                                          # [OPTIONAL]
CHATBOT_PORT=8003                                               # [OPTIONAL]
DISPATCH_PORT=8004                                              # [OPTIONAL]

# =============================================================================
# NEXT.JS PUBLIC (exposed to browser — prefix with NEXT_PUBLIC_)
# =============================================================================
NEXT_PUBLIC_TRIAGE_API_URL=http://localhost:8001                # [REQUIRED]
NEXT_PUBLIC_LOADSHEDDING_API_URL=http://localhost:8002          # [REQUIRED]
NEXT_PUBLIC_CHATBOT_API_URL=http://localhost:8003               # [REQUIRED]
NEXT_PUBLIC_DISPATCH_API_URL=http://localhost:8004              # [REQUIRED]
