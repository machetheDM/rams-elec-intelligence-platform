# =============================================================================
# Rams @Elec Intelligence Platform — .gitignore
# =============================================================================

# --- Node.js / Next.js ---
node_modules/
.next/
out/
*.tsbuildinfo
next-env.d.ts
.pnp
.pnp.js

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/
.venv/
venv/
env/
*.so

# --- ML Artifacts (too large for GitHub) ---
*.pkl
*.joblib
*.h5
*.keras
*.pb
*.onnx
faiss_index/
ml/models/*.bin
ml/models/*.safetensors
mlruns/
mlartifacts/

# --- Airflow ---
airflow/logs/
airflow/airflow.db
airflow/airflow.cfg
airflow/plugins/

# --- Environment Files ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# --- OS Files ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- IDE Files ---
.vscode/settings.json
.vscode/tasks.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~

# --- Secrets ---
*.pem
*.key
*.p12
*.pfx
serviceAccount*.json
credentials*.json
*-credentials.json
.streamlit/secrets.toml

# --- Docker ---
docker-compose.override.yml

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Testing ---
coverage/
.coverage
htmlcov/
.pytest_cache/
.tox/

# --- Database ---
*.db
*.db-journal
prisma/migrations/*/migration_lock.toml

# --- n8n ---
n8n/nodes/
n8n/credentials/

# --- Misc ---
*.tmp
*.temp
.cache/
.npm/
.eslintcache
